generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  publishedAt DateTime @default(now())
  views       Int      @default(0)
}

model BioscannerLaunch {
  id            String   @id @default(cuid())
  name          String
  lastname      String
  email         String   @unique
  organization  String
  country       String
  have_computer Boolean
  monitoring    Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Contact {
  id               String   @id @default(cuid())
  name             String
  lastname         String
  email            String   @unique
  gender           String?
  organization     String?
  country          String?
  active           Boolean  @default(true)
  data_agreement   Boolean  @default(false)
  policy_agreement Boolean  @default(false)
  createdAt        DateTime @default(now())
}
